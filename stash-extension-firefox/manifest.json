{
  "manifest_version": 3,
  "name": "STASH — Tab Vault",
  "version": "1.0.2",
  "description": "Stash any tab in one click and keep it searchable in a beautiful, local-first vault. No account, no cloud.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Stash this tab"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": ["tabs", "storage"],
  "commands": {
    "save-tab": {
      "suggested_key": { "default": "Alt+Shift+S", "mac": "Alt+Shift+S" },
      "description": "Quick-save the current tab to the vault"
    },
    "open-vault": {
      "suggested_key": { "default": "Ctrl+Shift+K", "mac": "Command+Shift+K" },
      "description": "Open the vault"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "stash-tab-vault@stash.local",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
